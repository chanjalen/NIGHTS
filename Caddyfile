# Caddy edge proxy. Automatic HTTPS (Let's Encrypt) for every site listed below.
# WebSocket upgrades and the X-Forwarded-Proto header (which Django reads via
# SECURE_PROXY_SSL_HEADER) are handled by reverse_proxy automatically.

{
	# Email used for the ACME (Let's Encrypt) account / expiry notices.
	email admin@findyournights.com
}

api.findyournights.com {
	reverse_proxy api:8000
}

api-dev.findyournights.com {
	# Private dev. Serve only requests from my IP ({$DEV_ALLOW_IP}) or Vercel's
	# SSR (which sends the shared-secret header — browser fetches can't, so they
	# rely on the IP rule). Everyone else gets 403. Both values are injected from
	# .env.caddy into the caddy container env (never committed). Load-time {$...}
	# substitution so remote_ip parses a concrete CIDR.
	@blocked {
		not remote_ip {$DEV_ALLOW_IP}
		not header X-Dev-Proxy-Secret "{$DEV_PROXY_SECRET}"
	}
	handle @blocked {
		respond 403
	}
	handle {
		reverse_proxy api-dev:8000
	}
}
