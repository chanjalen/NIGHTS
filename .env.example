# Copy to .env and fill in real values. NEVER commit the real .env.

# ─── Django ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DJANGO_SETTINGS_MODULE=config.settings.local
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ─── Database (Supabase Session Pooler) ──────────────────────────────────────
DB_NAME=postgres
DB_USER=postgres.your-project-ref
DB_PASSWORD=your-db-password
DB_HOST=aws-1-REGION.pooler.supabase.com
DB_PORT=5432

# ─── Google OAuth + Places ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# ─── Email (verification + password reset) ───────────────────────────────────
# Leave these blank in dev: emails (incl. verification links) print to the API
# container logs via the console backend. In production, set EMAIL_HOST and the
# rest to switch to real SMTP (SendGrid / SES / Resend / etc.) automatically.
# EMAIL_HOST=smtp.your-provider.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-smtp-username
# EMAIL_HOST_PASSWORD=your-smtp-password
# EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=NITE <no-reply@your-domain.com>

# ─── Redis / Celery ──────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/0

# ─── AWS S3 + CloudFront (review + chat media) ───────────────────────────────
AWS_ACCESS_KEY_ID=your-iam-access-key-id
AWS_SECRET_ACCESS_KEY=your-iam-secret-access-key
AWS_S3_BUCKET=your-bucket-name
AWS_S3_REGION=us-east-2
AWS_CLOUDFRONT_DOMAIN=dxxxxxxxxxxxxx.cloudfront.net
# CloudFront signed URLs for private chat media (optional in dev — falls back to
# unsigned). The private key file is mounted, never committed.
AWS_CLOUDFRONT_KEY_PAIR_ID=Kxxxxxxxxxxxxx
AWS_CLOUDFRONT_PRIVATE_KEY_FILE=/app/secrets/cf_private_key.pem

# ─── Analytics (PostHog) ─────────────────────────────────────────────────────
# One PostHog project covers product analytics (frontend) + cost-event tracking
# (backend). Leave blank to disable — all tracking no-ops. The frontend uses the
# NEXT_PUBLIC_* vars (must be set at build time in Vercel); the backend uses
# POSTHOG_API_KEY. They share the same project key.
# POSTHOG_API_KEY=phc_xxxxxxxxxxxxxxxxxxxx
# POSTHOG_HOST=https://us.i.posthog.com
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
