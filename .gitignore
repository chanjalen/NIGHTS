# ─────────────────────────────────────────────────────────────────────────────
# SECRETS — never commit. (.env holds DB creds, OAuth + AWS keys; secrets/ holds
# the CloudFront private signing key.)
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.keystore
secrets/
backend/secrets/
**/secrets/
*credentials*.json
service-account*.json

# ─── Python / Django ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
dist/
build/
.venv/
venv/
env/
ENV/
.Python
pip-log.txt
backend/staticfiles/
backend/media/
